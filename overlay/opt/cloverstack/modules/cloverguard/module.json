{
  "name": "cloverguard",
  "display_name": "CloverGuard",
  "description": "DNS-level ad blocking and web proxy",
  "version": "1.0.0",
  "category": "security",
  "ports": {
    "pihole": 8085,
    "dns": 53,
    "squid": 3128
  },
  "url_path": "/guard",
  "upstream": "Pi-hole + Squid",
  "upstream_license": "EUPL-1.2 + GPL-2.0",
  "min_ram_mb": 512,
  "min_disk_gb": 5,
  "default_enabled": false,
  "services": [
    "pihole",
    "squid"
  ]
}
