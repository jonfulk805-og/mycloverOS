# =============================================================================
# CloverStack Environment Configuration
# Copy to .env and customize for your deployment
# =============================================================================

# --- Global ---
TZ=America/Los_Angeles
HOST_IP=0.0.0.0

# --- NetMon (Zabbix) ---
NETMON_DB_PASSWORD=change-me-netmon

# --- SentryLog (Graylog + Wazuh) ---
SENTRYLOG_SECRET=change-me-minimum-16-characters
SENTRYLOG_ROOT_SHA2=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918
WAZUH_INDEXER_PASSWORD=SecretPassword

# --- MyClover Vault (Vaultwarden) ---
VAULT_DOMAIN=https://vault.myclover.local
VAULT_SIGNUPS=true
VAULT_ADMIN_TOKEN=

# --- Chappie AI ---
CHAPPIE_SECRET=change-me-chappie-secret
CHAPPIE_DEFAULT_MODEL=phi3:mini
CHAPPIE_SIGNUP=true

# --- CloverMedia ---
MEDIA_LIBRARY=/opt/cloverstack/data/media
MUSIC_LIBRARY=/opt/cloverstack/data/media/music

# --- CloverGuard ---
GUARD_PASSWORD=change-me-guard

# --- CloverMine (opt-in) ---
MINE_POOL=pool.supportxmr.com:443
MINE_WALLET=YOUR_WALLET_ADDRESS
MINE_CPU_LIMIT=0.50

# --- CloverPOS (ERPNext) ---
POS_DB_ROOT_PASSWORD=change-me-pos-root
POS_DB_PASSWORD=change-me-pos

# --- CloverDesign ---
DESIGN_AUTH=false
DESIGN_USER=admin
DESIGN_PASSWORD=change-me-design

# --- CloverBot ---
BOT_REGISTRATION=true

# --- CloverDrone ---
DRONE_CONNECTION=tcp:host.docker.internal:5760

# --- CloverMesh ---
MESH_SERVER_NAME=clovermesh
MESH_MASTER_KEY=change-me-mesh-key

# --- CloverMesh Radio ---
RADIO_HOST=host.docker.internal
RADIO_PORT=4403

# --- StreamServer ---
STREAM_ADMIN_PASSWORD=change-me-stream

# --- Traefik ---
ACME_EMAIL=admin@myclover.local
