#!/usr/bin/env bash
# =============================================================================
# clovermesh -- Cluster Management CLI ("Fail to Anywhere")
# Subcommand of cloverstack-ctl: `cloverstack-ctl mesh <command>`
# =============================================================================
set -euo pipefail

MESH_ROOT="/opt/cloverstack/clovermesh"
MESH_CONFIG="/etc/myclover/clovermesh.d"
MESH_STATE="/var/lib/clovermesh/state"
MESH_LOG="/var/log/clovermesh"
MESH_KEYS="${MESH_ROOT}/keys"

[[ -f "${MESH_CONFIG}/defaults.conf" ]] && source "${MESH_CONFIG}/defaults.conf"

log() { echo "[clovermesh] $*"; }
err() { echo "[clovermesh] ERROR: $*" >&2; }
warn() { echo "[clovermesh] WARNING: $*" >&2; }

usage() {
    cat <<EOF
CloverMesh — "Fail to Anywhere" Cluster Management
Usage: cloverstack-ctl mesh <command> [options]

Cluster Lifecycle:
  init --name <name> --node-ip <ip>        Initialize new cluster
  join --token <token> --node-ip <ip>       Join existing cluster
  leave                                     Gracefully leave cluster
  destroy                                   Destroy entire cluster (DANGER)
  status                                    Cluster health overview

Node Management:
  nodes                                     List all nodes
  promote <node>                            Manually promote to primary
  demote <node>                             Demote to replica
  fence <node>                              Force-isolate node
  maintenance start|stop <node> [--reason]  Maintenance mode

Replication:
  replicate --dataset <ds> --mode sync|async [--interval <sec>]
  replicate status                          Replication lag & health
  replicate verify                          Deep integrity check
  replicate pause|resume                    Pause/resume replication

Failover:
  failover test [--kill-node <n>] [--dry-run]  Test failover
  failover force <node>                     Force failover to node
  failover cloud                            Activate cloud failover
  failover dns                              Configure DNS failover

Cloud:
  add-cloud --provider <p> [--plan <plan>]  Add cloud failover node
  remove-cloud                              Remove cloud node
  cloud status                              Cloud node health

Services:
  services                                  List HA services
  migrate <service> <node>                  Move service to node
  balance                                   Rebalance services

Updates:
  update --rolling                          Zero-downtime rolling update
  update --check                            Check for updates

Monitoring:
  logs [--follow]                           Cluster event log
  alerts                                    Active alerts
  history                                   Failover history

EOF
}

# =============================================================================
# CLUSTER INITIALIZATION
# =============================================================================

cmd_init() {
    local cluster_name=""
    local node_ip=""
    local site=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name)    cluster_name="$2"; shift 2 ;;
            --node-ip) node_ip="$2"; shift 2 ;;
            --site)    site="$2"; shift 2 ;;
            *)         shift ;;
        esac
    done

    if [[ -z "${cluster_name}" || -z "${node_ip}" ]]; then
        err "Usage: cloverstack-ctl mesh init --name <cluster-name> --node-ip <ip>"
        exit 1
    fi

    local node_name
    node_name=$(hostname)

    log "Initializing CloverMesh cluster '${cluster_name}'..."
    log "Node: ${node_name} (${node_ip})"

    # Generate cluster join token
    local token
    token="CMESH-$(openssl rand -hex 4)-$(openssl rand -hex 4)-$(openssl rand -hex 4)"

    # Generate WireGuard keypair for this node
    mkdir -p "${MESH_KEYS}"
    wg genkey | tee "${MESH_KEYS}/privatekey" | wg pubkey > "${MESH_KEYS}/publickey"
    chmod 600 "${MESH_KEYS}/privatekey"

    # Generate cluster auth key
    openssl rand -hex 32 > "${MESH_KEYS}/authkey"
    chmod 600 "${MESH_KEYS}/authkey"

    # Configure Corosync
    log "Configuring Corosync cluster messaging..."

    local authkey
    authkey=$(cat "${MESH_KEYS}/authkey")

    cat > /etc/corosync/corosync.conf <<COROSYNC
totem {
    version: 2
    cluster_name: ${cluster_name}
    transport: knet
    crypto_cipher: aes256
    crypto_hash: sha256
}

nodelist {
    node {
        ring0_addr: ${node_ip}
        name: ${node_name}
        nodeid: 1
    }
}

quorum {
    provider: corosync_votequorum
    two_node: 0
    wait_for_all: 0
}

logging {
    to_logfile: yes
    logfile: /var/log/clovermesh/corosync.log
    to_syslog: yes
    timestamp: on
}
COROSYNC

    # Generate Corosync auth key
    corosync-keygen -l 2>/dev/null || dd if=/dev/urandom of=/etc/corosync/authkey bs=128 count=1 2>/dev/null
    chmod 400 /etc/corosync/authkey

    # Configure Keepalived (Virtual IP)
    local vip
    # Auto-assign VIP as .100 in same subnet
    vip=$(echo "${node_ip}" | sed 's/\.[0-9]*$/.100/')

    cat > /etc/keepalived/keepalived.conf <<KEEPALIVED
global_defs {
    router_id ${node_name}
    script_user root
    enable_script_security
}

vrrp_script chk_cluster {
    script "/opt/cloverstack/clovermesh/scripts/check-cluster.sh"
    interval 2
    weight -50
    fall 3
    rise 2
}

vrrp_instance VI_CLOVER {
    state MASTER
    interface eth0
    virtual_router_id 51
    priority 100
    advert_int 1
    authentication {
        auth_type PASS
        auth_pass ${authkey:0:8}
    }
    virtual_ipaddress {
        ${vip}/24
    }
    track_script {
        chk_cluster
    }
}
KEEPALIVED

    # Create cluster health check script
    mkdir -p "${MESH_ROOT}/scripts"
    cat > "${MESH_ROOT}/scripts/check-cluster.sh" <<'HEALTHCHK'
#!/bin/bash
# CloverMesh health check for Keepalived
# Returns 0 if healthy, 1 if unhealthy

# Check Corosync
if ! corosync-cfgtool -s &>/dev/null; then
    exit 1
fi

# Check Pacemaker
if ! crm_mon -1 &>/dev/null; then
    exit 1
fi

# Check ZFS pools health
if zpool list &>/dev/null; then
    if zpool status -x 2>/dev/null | grep -q "DEGRADED\|FAULTED\|OFFLINE\|UNAVAIL"; then
        exit 1
    fi
fi

exit 0
HEALTHCHK
    chmod +x "${MESH_ROOT}/scripts/check-cluster.sh"

    # Configure WireGuard mesh interface
    cat > /etc/wireguard/clovermesh0.conf <<WGCONF
[Interface]
Address = 10.42.0.1/24
ListenPort = 51820
PrivateKey = $(cat ${MESH_KEYS}/privatekey)
PostUp = iptables -A FORWARD -i clovermesh0 -j ACCEPT
PostDown = iptables -D FORWARD -i clovermesh0 -j ACCEPT

# Peers added by 'cloverstack-ctl mesh join'
WGCONF
    chmod 600 /etc/wireguard/clovermesh0.conf

    # Save cluster state
    mkdir -p "${MESH_STATE}"
    cat > "${MESH_STATE}/cluster.json" <<STATE
{
    "cluster_name": "${cluster_name}",
    "join_token": "${token}",
    "created": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
    "vip": "${vip}",
    "site": "${site:-default}",
    "nodes": [
        {
            "name": "${node_name}",
            "ip": "${node_ip}",
            "role": "primary",
            "id": 1,
            "wireguard_pubkey": "$(cat ${MESH_KEYS}/publickey)",
            "mesh_ip": "10.42.0.1"
        }
    ]
}
STATE

    # Start services
    systemctl enable --now corosync 2>/dev/null || warn "Corosync start deferred"
    systemctl enable --now pacemaker 2>/dev/null || warn "Pacemaker start deferred"
    systemctl enable --now wg-quick@clovermesh0 2>/dev/null || warn "WireGuard start deferred"
    # Don't start keepalived until 2+ nodes
    systemctl enable keepalived 2>/dev/null || true

    # Save state
    echo "${cluster_name}" > "${MESH_STATE}/cluster_name"
    echo "${node_name}" > "${MESH_STATE}/node_name"
    echo "primary" > "${MESH_STATE}/node_role"

    echo ""
    echo "╔══════════════════════════════════════════════════════╗"
    echo "║  ✅ CloverMesh Initialized: ${cluster_name}"
    echo "║"
    echo "║  🔑 Join token: ${token}"
    echo "║"
    echo "║  Run this on other nodes to join:"
    echo "║    cloverstack-ctl mesh join \\"
    echo "║      --token ${token} \\"
    echo "║      --node-ip <THIS_NODE_IP>"
    echo "║"
    echo "║  Virtual IP: ${vip}"
    echo "╚══════════════════════════════════════════════════════╝"
    echo ""
}

# =============================================================================
# CLUSTER JOIN
# =============================================================================

cmd_join() {
    local token=""
    local node_ip=""
    local site=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --token)   token="$2"; shift 2 ;;
            --node-ip) node_ip="$2"; shift 2 ;;
            --site)    site="$2"; shift 2 ;;
            *)         shift ;;
        esac
    done

    if [[ -z "${token}" || -z "${node_ip}" ]]; then
        err "Usage: cloverstack-ctl mesh join --token <CMESH-xxxx-xxxx-xxxx> --node-ip <ip>"
        exit 1
    fi

    local node_name
    node_name=$(hostname)

    log "Joining CloverMesh cluster with token ${token}..."
    log "Node: ${node_name} (${node_ip})"

    # Generate WireGuard keypair
    mkdir -p "${MESH_KEYS}"
    wg genkey | tee "${MESH_KEYS}/privatekey" | wg pubkey > "${MESH_KEYS}/publickey"
    chmod 600 "${MESH_KEYS}/privatekey"

    # TODO: Contact primary node via token to:
    # 1. Authenticate with cluster
    # 2. Get Corosync config + authkey
    # 3. Get WireGuard peers
    # 4. Get current cluster state
    # 5. Register this node

    log "Discovering cluster primary..."
    # For now, manual: copy corosync authkey + config from primary

    echo ""
    echo "╔═══════════════════════════════════════════════════════════╗"
    echo "║  Node ready to join cluster.                              ║"
    echo "║                                                           ║"
    echo "║  Complete setup:                                          ║"
    echo "║  1. On primary node, run:                                 ║"
    echo "║     cloverstack-ctl mesh add-node \\                      ║"
    echo "║       --name ${node_name} \\                              ║"
    echo "║       --ip ${node_ip} \\                                  ║"
    echo "║       --pubkey $(cat ${MESH_KEYS}/publickey)              ║"
    echo "║                                                           ║"
    echo "║  2. Copy /etc/corosync/authkey from primary to this node  ║"
    echo "║                                                           ║"
    echo "║  3. Start: systemctl start corosync pacemaker             ║"
    echo "╚═══════════════════════════════════════════════════════════╝"
    echo ""
}

# =============================================================================
# STATUS
# =============================================================================

cmd_status() {
    echo ""
    echo "╔══════════════════════════════════════════════════════════╗"

    local cluster_name
    cluster_name=$(cat "${MESH_STATE}/cluster_name" 2>/dev/null || echo "not initialized")
    echo "║  CloverMesh: ${cluster_name}"

    # Count nodes
    local total_nodes=0
    local online_nodes=0
    if command -v crm_mon &>/dev/null; then
        total_nodes=$(crm_mon -1 2>/dev/null | grep -c "Online:" || echo 0)
        online_nodes=$(crm_mon -1 2>/dev/null | grep "Online:" | tr ' ' '\n' | grep -c '\[' || echo 0)
    fi

    # Quorum
    local quorum="❌"
    if corosync-quorumtool 2>/dev/null | grep -q "Quorate:.*Yes"; then
        quorum="✅"
    fi

    echo "║  Nodes: ${online_nodes}/${total_nodes} online | Quorum: ${quorum}"
    echo "╠══════════════════════════════════════════════════════════╣"

    # Node list
    if [[ -f "${MESH_STATE}/cluster.json" ]]; then
        python3 -c "
import json
with open('${MESH_STATE}/cluster.json') as f:
    data = json.load(f)
print('║  {:15s} {:15s} {:10s} {:10s}'.format('Node', 'IP', 'Role', 'Status'))
for node in data.get('nodes', []):
    print('║  {:15s} {:15s} {:10s} {:10s}'.format(
        node['name'], node['ip'], node['role'], '✅ Online'))
" 2>/dev/null || echo "║  (cluster state unavailable)"
    fi

    echo "╠══════════════════════════════════════════════════════════╣"

    # Mesh links
    local wg_peers=0
    if command -v wg &>/dev/null; then
        wg_peers=$(wg show clovermesh0 2>/dev/null | grep -c "peer:" || echo 0)
    fi
    echo "║  Mesh Links: ${wg_peers} active (WireGuard)"

    # Replication
    local drbd_status="not configured"
    if command -v drbdadm &>/dev/null; then
        drbd_status=$(cat /proc/drbd 2>/dev/null | grep "cs:" | head -1 || echo "not active")
    fi
    echo "║  DRBD: ${drbd_status}"

    # VIP
    local vip
    vip=$(cat "${MESH_STATE}/cluster.json" 2>/dev/null | python3 -c "import json,sys;print(json.load(sys.stdin).get('vip','not set'))" 2>/dev/null || echo "not set")
    local vip_host
    vip_host=$(ip addr show 2>/dev/null | grep "${vip}" | awk '{print $NF}' || echo "none")
    echo "║  Virtual IP: ${vip} → ${vip_host}"

    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""
}

# =============================================================================
# REPLICATION
# =============================================================================

cmd_replicate() {
    local dataset=""
    local mode=""
    local interval=""
    local target=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dataset)  dataset="$2"; shift 2 ;;
            --mode)     mode="$2"; shift 2 ;;
            --interval) interval="$2"; shift 2 ;;
            --target)   target="$2"; shift 2 ;;
            status)     cmd_replicate_status; return ;;
            verify)     cmd_replicate_verify; return ;;
            *)          shift ;;
        esac
    done

    if [[ -z "${dataset}" || -z "${mode}" ]]; then
        err "Usage: cloverstack-ctl mesh replicate --dataset <ds> --mode sync|async [--interval 60s]"
        exit 1
    fi

    log "Configuring ${mode} replication for ${dataset}..."

    case "${mode}" in
        sync)
            log "Setting up DRBD synchronous replication for ${dataset}"
            log "All writes will be confirmed on 2+ nodes before ACK to client"
            # DRBD resource config would be generated here
            ;;
        async)
            interval="${interval:-60s}"
            log "Setting up ZFS async replication for ${dataset} (interval: ${interval})"
            # ZFS send/receive cron would be configured here
            ;;
        *)
            err "Unknown mode: ${mode}. Use sync or async."
            exit 1
            ;;
    esac

    log "Replication configured for ${dataset}"
}

cmd_replicate_status() {
    echo ""
    echo "=== Replication Status ==="
    echo ""

    # DRBD status
    echo "--- DRBD (Synchronous) ---"
    if [[ -f /proc/drbd ]]; then
        cat /proc/drbd
    else
        echo "  DRBD not active"
    fi
    echo ""

    # ZFS replication status
    echo "--- ZFS Send/Receive (Asynchronous) ---"
    echo "  (Check cron jobs and logs at ${MESH_LOG}/replication.log)"
    echo ""
}

cmd_replicate_verify() {
    log "Running deep replication integrity check..."
    echo ""

    # Verify ZFS checksums
    echo "=== ZFS Checksum Verification ==="
    zpool scrub -w $(zpool list -H -o name 2>/dev/null | head -1) 2>/dev/null || echo "  No pools to verify"
    echo ""

    log "Verification complete"
}

# =============================================================================
# FAILOVER
# =============================================================================

cmd_failover_test() {
    local kill_node=""
    local dry_run=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --kill-node) kill_node="$2"; shift 2 ;;
            --dry-run)   dry_run=true; shift ;;
            *)           shift ;;
        esac
    done

    if [[ "${dry_run}" == "true" ]]; then
        log "DRY RUN: Simulating failover (no actual changes)"
    fi

    if [[ -n "${kill_node}" ]]; then
        log "Testing failover: simulating failure of ${kill_node}..."
        if [[ "${dry_run}" == "false" ]]; then
            # Put node in standby (simulates failure without actually killing it)
            crm node standby "${kill_node}"
            sleep 15
            log "Failover test complete. Restoring node..."
            crm node online "${kill_node}"
        else
            log "[DRY RUN] Would standby node ${kill_node}, wait 15s, then restore"
        fi
    else
        log "Testing general cluster failover readiness..."
        # Check all components
        echo "  Corosync: $(corosync-cfgtool -s 2>/dev/null | grep -c 'status.*ok' || echo 0) rings OK"
        echo "  Pacemaker: $(crm_mon -1 2>/dev/null | grep -c 'Online' || echo 0) nodes online"
        echo "  DRBD: $(cat /proc/drbd 2>/dev/null | grep -c 'UpToDate' || echo 0) devices synced"
        echo "  WireGuard: $(wg show clovermesh0 2>/dev/null | grep -c 'latest handshake' || echo 0) peers active"
        echo "  Keepalived: $(systemctl is-active keepalived 2>/dev/null || echo inactive)"
    fi
}

# =============================================================================
# MAINTENANCE MODE
# =============================================================================

cmd_maintenance() {
    local action="$1"; shift
    local node="$1"; shift
    local reason=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --reason) reason="$2"; shift 2 ;;
            *)        shift ;;
        esac
    done

    case "${action}" in
        start)
            log "Entering maintenance mode for ${node}..."
            [[ -n "${reason}" ]] && log "Reason: ${reason}"
            crm node maintenance "${node}" 2>/dev/null || crm node standby "${node}"
            log "Services migrated. ${node} is now in maintenance mode."
            log "Do your maintenance, then: cloverstack-ctl mesh maintenance stop ${node}"
            ;;
        stop)
            log "Exiting maintenance mode for ${node}..."
            crm node ready "${node}" 2>/dev/null || crm node online "${node}"
            log "${node} is back online. Resyncing..."
            ;;
    esac
}

# =============================================================================
# ROLLING UPDATE
# =============================================================================

cmd_update_rolling() {
    log "Starting zero-downtime rolling update..."

    if [[ ! -f "${MESH_STATE}/cluster.json" ]]; then
        err "No cluster state found. Is this node in a cluster?"
        exit 1
    fi

    local nodes
    nodes=$(python3 -c "
import json
with open('${MESH_STATE}/cluster.json') as f:
    data = json.load(f)
# Update replicas first, primary last
sorted_nodes = sorted(data['nodes'], key=lambda n: 0 if n['role'] != 'primary' else 1)
for n in sorted_nodes:
    print(n['name'])
")

    for node in ${nodes}; do
        log "Updating node: ${node}"
        log "  1. Migrating services off ${node}..."
        crm node standby "${node}" 2>/dev/null || true
        sleep 5

        log "  2. Running myclover-update on ${node}..."
        if [[ "${node}" == "$(hostname)" ]]; then
            /usr/local/bin/myclover-update 2>/dev/null || true
        else
            ssh "${node}" "/usr/local/bin/myclover-update" 2>/dev/null || true
        fi

        log "  3. Rebooting ${node}..."
        if [[ "${node}" == "$(hostname)" ]]; then
            # Self-reboot handled last
            true
        else
            ssh "${node}" "reboot" 2>/dev/null || true
            sleep 30  # Wait for reboot
        fi

        log "  4. Bringing ${node} back online..."
        crm node online "${node}" 2>/dev/null || true
        sleep 10

        log "  ✅ ${node} updated"
    done

    log "Rolling update complete — zero downtime achieved"
}

# =============================================================================
# MAIN DISPATCH
# =============================================================================

COMMAND="${1:-}"
shift 1 2>/dev/null || true

case "${COMMAND}" in
    init)           cmd_init "$@" ;;
    join)           cmd_join "$@" ;;
    leave)          log "Leaving cluster..."; crm node standby "$(hostname)"; systemctl stop corosync pacemaker ;;
    destroy)        err "DANGER: This destroys the entire cluster. Use --yes-i-am-sure to confirm." ;;
    status)         cmd_status ;;
    nodes)          crm_mon -1 2>/dev/null || echo "Cluster not active" ;;
    promote)        crm node online "$@"; log "Node promoted" ;;
    demote)         crm node standby "$@"; log "Node demoted to standby" ;;
    fence)          crm node fence "$@" 2>/dev/null || stonith_admin --fence "$@" ;;
    maintenance)    cmd_maintenance "$@" ;;
    replicate)      cmd_replicate "$@" ;;
    failover)
        subcmd="${1:-}"; shift 2>/dev/null || true
        case "${subcmd}" in
            test)   cmd_failover_test "$@" ;;
            force)  crm node standby "$(hostname)"; crm resource move --force "$@" ;;
            cloud)  log "Activating cloud failover..." ;;
            dns)    log "Configuring DNS failover..." ;;
            *)      usage ;;
        esac
        ;;
    add-cloud)      log "Adding cloud failover node..." ;;
    remove-cloud)   log "Removing cloud node..." ;;
    cloud)          log "Cloud status: checking..." ;;
    services)       crm_mon -1 2>/dev/null | grep -A100 "Active Resources" || echo "No HA services" ;;
    migrate)        crm resource move "$@" ;;
    balance)        crm resource cleanup 2>/dev/null; log "Services rebalanced" ;;
    update)
        subcmd="${1:-}"; shift 2>/dev/null || true
        case "${subcmd}" in
            --rolling) cmd_update_rolling ;;
            --check)   /usr/local/bin/myclover-update --check 2>/dev/null || echo "No updates available" ;;
            *)         usage ;;
        esac
        ;;
    logs)           tail -f "${MESH_LOG}"/*.log 2>/dev/null || echo "No logs yet" ;;
    alerts)         crm_mon -1 2>/dev/null | grep -iE "fail|error|warn|degrad" || echo "No active alerts" ;;
    history)        crm_mon -1 -o 2>/dev/null || echo "No failover history" ;;
    *)              usage ;;
esac
