#!/bin/bash
# =============================================================================
# CloverVR — VR Server Management Script
# Part of mycloverOS / CloverStack
# =============================================================================

set -euo pipefail

SCRIPT_NAME="clovervr"
CLOVERVR_DIR="/opt/cloverstack/clovervr"
DOCKER_COMPOSE="${CLOVERVR_DIR}/docker-compose.yml"
CONFIG_FILE="/etc/cloverstack/clovervr.conf"
LOG_FILE="/var/log/cloverstack/clovervr.log"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

log() { echo -e "${GREEN}[CloverVR]${NC} $1"; }
warn() { echo -e "${YELLOW}[CloverVR WARN]${NC} $1"; }
error() { echo -e "${RED}[CloverVR ERROR]${NC} $1" >&2; }

show_help() {
    echo -e "${PURPLE}CloverVR${NC} — VR Server Management"
    echo ""
    echo "Usage: ${SCRIPT_NAME} <command> [options]"
    echo ""
    echo "Commands:"
    echo "  install         Install CloverVR components"
    echo "  start           Start VR streaming server"
    echo "  stop            Stop VR streaming server"
    echo "  restart         Restart VR services"
    echo "  status          Show VR server status"
    echo "  headsets        List connected headsets"
    echo "  stream          Manage streaming sessions"
    echo "  social          Manage social VR rooms"
    echo "  arcade          Manage arcade/kiosk mode"
    echo "  gpu             Show GPU status and utilization"
    echo "  config          Edit configuration"
    echo "  logs            View logs"
    echo "  update          Update CloverVR components"
    echo "  uninstall       Remove CloverVR"
    echo ""
    echo "Examples:"
    echo "  ${SCRIPT_NAME} install"
    echo "  ${SCRIPT_NAME} start"
    echo "  ${SCRIPT_NAME} headsets"
    echo "  ${SCRIPT_NAME} stream start --headset quest3"
    echo "  ${SCRIPT_NAME} arcade enable --timeout 30m"
    echo "  ${SCRIPT_NAME} gpu"
}

check_gpu() {
    if command -v nvidia-smi &> /dev/null; then
        log "NVIDIA GPU detected:"
        nvidia-smi --query-gpu=name,memory.total,memory.used,utilization.gpu --format=csv,noheader
    elif [ -d /sys/class/drm/card0 ]; then
        log "GPU detected (non-NVIDIA). Using VA-API encoding."
    else
        warn "No dedicated GPU detected. VR streaming requires a GPU."
        return 1
    fi
}

do_install() {
    log "Installing CloverVR components..."

    # Create directories
    mkdir -p "${CLOVERVR_DIR}" /etc/cloverstack /var/log/cloverstack

    # Check GPU
    check_gpu || warn "Continuing without GPU verification..."

    # Pull Docker images
    log "Pulling ALVR server image..."
    docker pull ghcr.io/alvr-org/alvr-server:latest 2>/dev/null || warn "ALVR image pull failed - will retry on start"

    log "Pulling Overte server image (social VR)..."
    docker pull overte/overte-server:latest 2>/dev/null || warn "Overte image pull failed - will retry on start"

    # Generate default config
    if [ ! -f "${CONFIG_FILE}" ]; then
        cat > "${CONFIG_FILE}" << 'CONF'
# CloverVR Configuration
# ======================

[server]
# VR streaming server settings
bind_address=0.0.0.0
web_dashboard_port=9100
alvr_port=9944
wivrn_port=9757

[streaming]
# Default streaming quality
resolution=2880x1600
framerate=90
bitrate_mbps=100
codec=h265
foveated_encoding=true
color_correction=true

[network]
# Wi-Fi optimization
wifi_channel_auto=true
qos_enabled=true
dedicated_vlan=false
srt_enabled=false

[social]
# Social VR settings
max_users_per_room=20
spatial_audio=true
voice_chat=true
custom_avatars=true

[arcade]
# Arcade / kiosk mode
enabled=false
default_timeout_minutes=30
auto_reset=true
billing_enabled=false

[ai]
# Chappie / Clover AI
ai_enabled=true
ai_personality=chappie
# Options: chappie, clover, custom
custom_ai_name=
voice_commands=true
performance_tuning=true
content_moderation=false
CONF
        log "Default config written to ${CONFIG_FILE}"
    fi

    # Create docker-compose
    cat > "${DOCKER_COMPOSE}" << 'COMPOSE'
version: '3.8'
services:
  alvr-server:
    image: ghcr.io/alvr-org/alvr-server:latest
    container_name: clovervr-alvr
    restart: unless-stopped
    network_mode: host
    privileged: true
    environment:
      - DISPLAY=:0
      - NVIDIA_VISIBLE_DEVICES=all
      - NVIDIA_DRIVER_CAPABILITIES=all
    volumes:
      - /tmp/.X11-unix:/tmp/.X11-unix
      - /etc/cloverstack/clovervr.conf:/etc/alvr/config.conf:ro
      - clovervr-data:/data
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]

  overte-server:
    image: overte/overte-server:latest
    container_name: clovervr-social
    restart: unless-stopped
    ports:
      - "40100-40102:40100-40102"
      - "40100-40102:40100-40102/udp"
      - "48000-48006:48000-48006/udp"
    volumes:
      - clovervr-social-data:/root/.local/share/Overte

  clovervr-dashboard:
    image: clovervr-dashboard:latest
    container_name: clovervr-web
    restart: unless-stopped
    ports:
      - "9100:9100"
    environment:
      - CLOVERVR_CONFIG=/etc/clovervr/config.conf
    volumes:
      - /etc/cloverstack/clovervr.conf:/etc/clovervr/config.conf:ro

volumes:
  clovervr-data:
  clovervr-social-data:
COMPOSE

    log "CloverVR installed successfully!"
    log "Run '${SCRIPT_NAME} start' to launch the VR server."
}

do_start() {
    log "Starting CloverVR services..."
    cd "${CLOVERVR_DIR}"
    docker compose up -d
    log "CloverVR is running!"
    log "Dashboard: http://$(hostname -I | awk '{print $1}'):9100"
    log "ALVR: port 9944 | Social VR: ports 40100-40102"
}

do_stop() {
    log "Stopping CloverVR services..."
    cd "${CLOVERVR_DIR}"
    docker compose down
    log "CloverVR stopped."
}

do_status() {
    log "CloverVR Status:"
    echo ""
    if [ -f "${DOCKER_COMPOSE}" ]; then
        cd "${CLOVERVR_DIR}"
        docker compose ps 2>/dev/null || warn "Services not running"
    else
        warn "CloverVR not installed. Run '${SCRIPT_NAME} install'"
    fi
    echo ""
    check_gpu 2>/dev/null || true
}

do_gpu() {
    if command -v nvidia-smi &> /dev/null; then
        nvidia-smi
    else
        log "GPU info:"
        lspci | grep -i vga
        echo ""
        if [ -f /sys/class/drm/card0/device/gpu_busy_percent ]; then
            echo "GPU Utilization: $(cat /sys/class/drm/card0/device/gpu_busy_percent)%"
        fi
    fi
}

# Main
case "${1:-help}" in
    install)    do_install ;;
    start)      do_start ;;
    stop)       do_stop ;;
    restart)    do_stop; sleep 2; do_start ;;
    status)     do_status ;;
    gpu)        do_gpu ;;
    headsets)   log "Scanning for connected headsets..."; echo "(Headset discovery runs via ALVR dashboard at :9944)" ;;
    stream)     log "Stream management via dashboard at :9100"; ;;
    social)     log "Social VR management via dashboard at :9100"; ;;
    arcade)     log "Arcade mode management via dashboard at :9100"; ;;
    config)     ${EDITOR:-nano} "${CONFIG_FILE}" ;;
    logs)       docker logs -f clovervr-alvr 2>/dev/null || warn "ALVR not running" ;;
    update)     log "Updating CloverVR..."; cd "${CLOVERVR_DIR}"; docker compose pull; docker compose up -d; log "Updated!" ;;
    uninstall)  log "Removing CloverVR..."; cd "${CLOVERVR_DIR}"; docker compose down -v; rm -rf "${CLOVERVR_DIR}"; log "Removed." ;;
    help|*)     show_help ;;
esac
