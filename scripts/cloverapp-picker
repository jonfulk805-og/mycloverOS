# Presets define which apps are auto-selected for common use cases
PRESETS = {
    "minimal": {
        "name": "Minimal",
        "description": "Essential services only",
        "apps": ["myclover-vault", "chappie"],
    },
    "home": {
        "name": "Home Server",
