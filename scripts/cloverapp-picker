#!/usr/bin/env python3
"""
CloverApp Picker — Interactive TUI for first-boot app selection.
Runs during myclover-install or first-boot provisioning.

Usage:
    cloverapp-picker                 # Interactive TUI mode
    cloverapp-picker --preset msp    # Auto-select a preset
    cloverapp-picker --headless      # Non-interactive (install defaults only)
"""

import curses
import json
import os
import subprocess
import sys
import textwrap

# =============================================================================
# App Catalog (built-in defaults + marketplace sync)
# =============================================================================

