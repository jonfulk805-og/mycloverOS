show_access_info() {
    local app_name="$1"
    local app_dir="${APPS_DIR}/${app_name}"

    echo ""
    echo -e "${BOLD}Access Information${NC}"
    echo "=================="

    if [[ -f "${app_dir}/cloverapp.yml" ]]; then
        python3 << PYEOF
import yaml

with open("${app_dir}/cloverapp.yml") as f:
    m = yaml.safe_load(f)

ports = m.get("networking", {}).get("ports", [])
for port in ports:
    subdomain = port.get("subdomain", "${app_name}")
    if port.get("traefik_route"):
        print(f"  Web UI:  https://{subdomain}.local.cloverstack")
    else:
        print(f"  Port:    {port.get('container_port', '?')}")

print(f"  Config:  /etc/myclover/apps/${app_name}/")
print(f"  Logs:    clovermarket logs ${app_name}")
PYEOF
    fi
    echo ""
}

cmd_logs() {
    local app_name="$1"
    local app_dir="${APPS_DIR}/${app_name}"

    if [[ ! -d "${app_dir}" ]]; then
        err "App '${app_name}' is not installed"
        exit 1
    fi

    docker compose -f "${app_dir}/docker-compose.yml" logs -f --tail=100
}

# =============================================================================
# Usage
# =============================================================================
usage() {
    cat << EOF

${BOLD}CloverMarket${NC} v${VERSION} -- Self-Hosted App Marketplace for mycloverOS

${BOLD}USAGE:${NC}
    clovermarket <command> [arguments]

${BOLD}BROWSE & DISCOVER:${NC}
    search [query]           Search the app marketplace
    info <app>               Show detailed app information
    status                   Show CloverMarket status & subscription

${BOLD}APP MANAGEMENT:${NC}
    install <app> [tier]     Install an app (tier: free|pro|enterprise)
    remove <app>             Remove an installed app
    upgrade <app>            Upgrade an app to latest version
    update                   Check & upgrade all installed apps
    tier <app> <tier>        Switch app tier (free/pro/enterprise)
    list                     List installed apps
    logs <app>               View app logs

${BOLD}CREATOR TOOLS:${NC}
    validate [manifest]      Validate a cloverapp.yml manifest
    submit [dir]             Submit app for marketplace review

${BOLD}EXAMPLES:${NC}
    clovermarket search "project management"
    clovermarket install wiki-server
    clovermarket install kanban-board pro
    clovermarket tier kanban-board enterprise
    clovermarket update

EOF
}

# =============================================================================
# Main Dispatch
# =============================================================================
init_dirs

COMMAND="${1:-}"
ARG1="${2:-}"
ARG2="${3:-}"

case "${COMMAND}" in
    search)     cmd_search "${ARG1}" ;;
    info)       [[ -n "${ARG1}" ]] && cmd_info "${ARG1}" || usage ;;
    install)    [[ -n "${ARG1}" ]] && cmd_install "${ARG1}" "${ARG2}" || usage ;;
    remove)     [[ -n "${ARG1}" ]] && cmd_remove "${ARG1}" || usage ;;
    upgrade)    [[ -n "${ARG1}" ]] && cmd_upgrade "${ARG1}" || usage ;;
    update)     cmd_update_all ;;
    tier)       [[ -n "${ARG1}" && -n "${ARG2}" ]] && cmd_tier "${ARG1}" "${ARG2}" || usage ;;
    list)       cmd_list_installed ;;
    logs)       [[ -n "${ARG1}" ]] && cmd_logs "${ARG1}" || usage ;;
    status)     cmd_status ;;
    validate)   cmd_validate "${ARG1:-cloverapp.yml}" ;;
    submit)     cmd_submit "${ARG1:-.}" ;;
    *)          usage ;;
esac
