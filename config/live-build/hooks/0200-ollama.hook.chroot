#!/bin/bash
# =============================================================================
# mycloverOS chroot hook -- Install Ollama AI Engine
# =============================================================================
set -e

echo "[mycloverOS] Installing Ollama..."

# Install Ollama
# zstd is required by Ollama installer for extraction
apt-get install -y zstd

curl -fsSL https://ollama.com/install.sh | sh

# Create systemd service (if not created by installer)
if [[ ! -f /etc/systemd/system/ollama.service ]]; then
    cat > /etc/systemd/system/ollama.service <<'EOF'
[Unit]
Description=Ollama AI Engine
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=/usr/local/bin/ollama serve
User=ollama
Group=ollama
Restart=always
RestartSec=3
Environment="HOME=/usr/share/ollama"
Environment="OLLAMA_HOST=0.0.0.0"

[Install]
WantedBy=default.target
EOF
fi

systemctl enable ollama 2>/dev/null || true

echo "[mycloverOS] Ollama installed"
