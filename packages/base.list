# =============================================================================
# mycloverOS Base Packages
# Included in ALL editions
# =============================================================================

# --- Core system ---
systemd
systemd-sysv
dbus
udev
init

# --- Kernel ---
linux-image-amd64

# --- Live system (REQUIRED for live CD boot) ---
# live-boot: initramfs hooks that find and mount the squashfs live filesystem
# live-config: live session setup (user creation, autologin, hostname, locale)
# Without these the kernel boots but drops to a blank screen / blinking cursor
live-boot
live-config
live-config-systemd

# --- Shell & utilities ---
bash
bash-completion
coreutils
findutils
grep
gawk
sed
less
file
tree
htop
btop
nano
vim-tiny
tmux
screen
curl
wget
rsync
zip
unzip
xz-utils
pigz

# --- Filesystem ---
e2fsprogs
xfsprogs
btrfs-progs
dosfstools
ntfs-3g
parted
gdisk
lvm2
cryptsetup
mdadm

# --- Networking core ---
iproute2
iputils-ping
net-tools
isc-dhcp-client
network-manager
dnsutils
nmap
tcpdump
iptables
nftables
ethtool
bridge-utils

# --- SSH ---
openssh-server
openssh-client

# --- Security ---
sudo
apparmor
apparmor-utils
fail2ban
ufw
ca-certificates
gnupg

# --- Python (for CloverStack scripts) ---
python3
python3-pip
python3-venv

# --- Container runtime ---
# Docker CE + Compose v2 plugin installed via build hook (0150-docker.hook.chroot)
# from Docker's official apt repo. Do NOT use Debian's docker.io (ships without
# the 'docker compose' v2 subcommand that CloverStack scripts require).

# --- System monitoring ---
lm-sensors
smartmontools
sysstat
iotop

# --- Hardware/firmware ---
pciutils
usbutils
dmidecode
lshw
inxi

# --- Time ---
chrony

# --- Logging ---
rsyslog
logrotate
