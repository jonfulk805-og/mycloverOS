# =============================================================================
# mycloverOS CloverNAS + CloverDeploy + CloverMesh Packages
# Storage, container/VM orchestration, and high-availability clustering
# =============================================================================

# --- ZFS (OpenZFS) ---
# ZFS is built from dkms source during hook because Debian bookworm's
# stock zfs packages live in contrib; the hook adds the repo and installs.
# See: 0300-clovernas.hook.chroot

# --- NAS protocol daemons ---
# SMB/CIFS file sharing
samba
samba-common-bin
# NFS v3/v4
nfs-kernel-server
nfs-common
# iSCSI target (LIO alternative)
# tgt  # trimmed: install via CloverMarket
# iSCSI initiator (for cluster replication)
# open-iscsi  # trimmed: install via CloverMarket
# FTP/SFTP
proftpd-basic

# --- S.M.A.R.T. disk monitoring ---
smartmontools

# --- Virtual machine support (KVM/QEMU) ---
# qemu-system-x86  # trimmed: install via CloverMarket
# qemu-utils  # trimmed: install via CloverMarket
# libvirt-daemon-system  # trimmed: install via CloverMarket
# libvirt-clients  # trimmed: install via CloverMarket
# virtinst  # trimmed: install via CloverMarket
# UEFI firmware for VMs
# ovmf  # trimmed: install via CloverMarket

# --- VM console access ---
# noVNC is deployed via Docker container (see CloverDeploy catalog)

# --- Cluster / High-Availability (CloverMesh) ---
# Cluster messaging + quorum
# corosync  # trimmed: install via CloverMarket
# Cluster resource manager
# pacemaker  # trimmed: install via CloverMarket
# Pacemaker/Corosync CLI
# pcs  # trimmed: install via CloverMarket
# Cluster resource shell
# crmsh  # trimmed: install via CloverMarket
# Fencing agents (IPMI, SSH, etc.)
# fence-agents  # trimmed: install via CloverMarket
# HA resource agents
# resource-agents  # trimmed: install via CloverMarket
# DRBD 9 block-level replication
# drbd-utils  # trimmed: install via CloverMarket
# Virtual IP (VIP) failover
keepalived

# --- Advanced networking for clusters ---
# FRRouting (OSPF/BGP for MAN clusters)
# frr  # trimmed: install via CloverMarket
# Open vSwitch (SDN for datacenter tier)
# openvswitch-switch  # trimmed: install via CloverMarket

# --- Backup ---
# restic already in cloverstack.list

# --- MinIO (S3-compatible object storage) ---
# Deployed via Docker container (see CloverDeploy catalog)

# --- Misc storage utilities ---
parted
gdisk
lsscsi
# NVMe drive management
nvme-cli
# Disk benchmarking
# fio  # trimmed: install via CloverMarket
# Filesystem benchmarking
# bonnie++  # trimmed: install via CloverMarket
# Compression (ZFS default)
zstd
# Fast compression (ZFS L2ARC)
lz4
